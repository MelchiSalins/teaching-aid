# ---------------------------------------------------------------------------
# Manim render outputs
# ---------------------------------------------------------------------------
# Manim writes all generated videos, images, intermediate TeX, and SVG files
# into the `media/` directory. These are reproducible from the scene scripts
# and should not be committed.
media/

# Manim config / cache
.manim-cache/
manim.cfg.local

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
# NOTE: .python-version is intentionally NOT ignored — we commit it so
# `uv` (and pyenv) pick the right interpreter automatically.

# ---------------------------------------------------------------------------
# Environments / secrets
# ---------------------------------------------------------------------------
.env.local
.env.*.local
*.local

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
# Commit shared workspace config (interpreter pin, recommended extensions,
# tasks/launch configs) but ignore per-user state.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.swn
*~

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# ---------------------------------------------------------------------------
# Windows
# ---------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Logs / temp
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
